generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  owner
  member
}

enum InviteStatus {
  pending
  accepted
  revoked
  expired
}

enum TodoStatus {
  todo
  in_progress
  blocked
  done
}

enum Priority {
  low
  medium
  high
  urgent
}

enum RoadmapStatus {
  planned
  in_progress
  blocked
  done
}

enum PomodoroStatus {
  completed
  interrupted
  abandoned
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions         Session[]
  ownedWorkspaces  Workspace[]       @relation("WorkspaceOwner")
  memberships      WorkspaceMember[]
  sentInvites      WorkspaceInvite[] @relation("WorkspaceInviteSender")
  createdTodos     Todo[]            @relation("TodoCreator")
  assignedTodos    Todo[]            @relation("TodoAssignee")
  pomodoroSessions PomodoroSession[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuthRateLimit {
  key         String   @id
  attempts    Int
  windowStart DateTime
  expiresAt   DateTime

  @@index([expiresAt])
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner            User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members          WorkspaceMember[]
  invites          WorkspaceInvite[]
  todos            Todo[]
  labels           Label[]
  roadmapItems     RoadmapItem[]
  pomodoroSessions PomodoroSession[]

  @@index([ownerId])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(member)
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model WorkspaceInvite {
  id          String        @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole @default(member)
  status      InviteStatus  @default(pending)
  invitedById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("WorkspaceInviteSender", fields: [invitedById], references: [id], onDelete: Restrict)

  @@index([workspaceId, status])
  @@index([email])
  @@index([invitedById])
}

model Todo {
  id            String     @id @default(cuid())
  workspaceId   String
  creatorId     String
  assigneeId    String?
  roadmapItemId String?
  title         String
  description   String?
  status        TodoStatus @default(todo)
  priority      Priority   @default(medium)
  dueDate       DateTime?  @db.Date
  plannedDate   DateTime?  @db.Date
  completedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator          User              @relation("TodoCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  assignee         User?             @relation("TodoAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  roadmapItem      RoadmapItem?      @relation(fields: [roadmapItemId], references: [id], onDelete: SetNull)
  labels           TodoLabel[]
  pomodoroSessions PomodoroSession[]

  @@index([workspaceId, status])
  @@index([workspaceId, dueDate])
  @@index([workspaceId, plannedDate])
  @@index([creatorId])
  @@index([assigneeId])
  @@index([roadmapItemId])
}

model Label {
  id          String @id @default(cuid())
  workspaceId String
  name        String
  color       String

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  todos     TodoLabel[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model TodoLabel {
  todoId  String
  labelId String

  todo  Todo  @relation(fields: [todoId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([todoId, labelId])
  @@index([labelId])
}

model RoadmapItem {
  id          String        @id @default(cuid())
  workspaceId String
  title       String
  description String?
  status      RoadmapStatus @default(planned)
  priority    Priority      @default(medium)
  startDate   DateTime?     @db.Date
  targetDate  DateTime?     @db.Date
  position    Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  todos     Todo[]

  @@index([workspaceId, status])
  @@index([workspaceId, position])
}

model PomodoroSession {
  id              String         @id @default(cuid())
  workspaceId     String
  userId          String
  todoId          String?
  startedAt       DateTime
  endedAt         DateTime?
  durationMinutes Int
  status          PomodoroStatus
  createdAt       DateTime       @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  todo      Todo?     @relation(fields: [todoId], references: [id], onDelete: SetNull)

  @@index([workspaceId, startedAt])
  @@index([userId, startedAt])
  @@index([todoId])
}
